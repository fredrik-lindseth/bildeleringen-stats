{
  "manifest_version": 3,
  "name": "Bildeleringen Stats",
  "version": "1.1.0",
  "description": "Statistikk og analyse av ditt bildeleforbruk på dele.no",
  "permissions": ["storage", "unlimitedStorage", "scripting"],
  "host_permissions": ["*://app.dele.no/*"],
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://app.dele.no/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "theme_icons": [
      { "size": 16, "light": "icons/icon-16.png", "dark": "icons/icon-dark-16.png" },
      { "size": 48, "light": "icons/icon-48.png", "dark": "icons/icon-dark-48.png" },
      { "size": 128, "light": "icons/icon-128.png", "dark": "icons/icon-dark-128.png" }
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bildeleringen-stats@extension",
      "strict_min_version": "112.0"
    }
  }
}
